# ArbiChain Environment Configuration
# Copy this file to .env and fill in your values

# ============ TRON Network ============
# Network: nile (testnet), shasta (testnet), mainnet
TRON_NETWORK=nile
TRON_FULL_HOST=https://nile.trongrid.io

# Private key for deploying contracts (64-char hex, no 0x prefix)
TRON_PRIVATE_KEY=

# ============ Contract Addresses ============
# Fill these in after deployment
ESCROW_ADDRESS=
REPUTATION_GATE_ADDRESS=
ARBI_TOKEN_ADDRESS=
ARBITRATOR_POOL_ADDRESS=

# ============ Agent Private Keys ============
# Each agent needs its own wallet
# Generate test wallets at: https://nileex.io/join/getJoinPage
BUYER_PRIVATE_KEY=
SELLER_PRIVATE_KEY=
ARBITRATOR_PRIVATE_KEY=

# ============ Filecoin Storage (Synapse SDK) ============
# Powered by Filecoin Onchain Cloud - https://docs.filecoin.cloud
# Network: calibration (testnet) or mainnet
FILECOIN_NETWORK=calibration

# Private key for Filecoin/Synapse (64-char hex WITH 0x prefix)
# This wallet needs:
# 1. Calibration FIL for gas: https://faucet.calibration.fildev.network/
# 2. USDFC tokens for storage payments (via Synapse SDK deposit)
FILECOIN_PRIVATE_KEY=0x...

# Optional: GLIF auth bearer token for improved upload reliability/rate limits
# Format: Bearer <token>
FILECOIN_AUTHORIZATION=

# ============ AI Agents (OpenAI) ============
# Used for GPT-powered seller, buyer review, and arbitrator analysis
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ============ Agent Behavior ============
# Polling interval in milliseconds
POLL_INTERVAL_MS=5000

# Transaction confirmation timeout
TX_CONFIRM_TIMEOUT_MS=60000

# Auto-approve deliverables (for demo purposes)
AUTO_APPROVE=false

# Arbitrator: set true only if you want the listen loop to auto-submit rulings (no human)
ARBITRATOR_AUTO_RESOLVE=false

# ============ OpenAI (Whistle LLM agents) ============
# https://platform.openai.com/api-keys — never commit real keys
OPENAI_API_KEY=
# e.g. gpt-4o, gpt-4-turbo
OPENAI_MODEL=gpt-4o

# When OPENAI_API_KEY is set, seller/buyer use the model unless disabled:
USE_LLM_SELLER=true
USE_LLM_BUYER=true
# Advisory only; human still signs resolve <taskId> 0|1
USE_LLM_ARBITRATOR_ASSIST=true

# Logging
VERBOSE=true
LOG_LEVEL=info

# ============ Task Settings ============
# Minimum task amount in SUN (1 TRX = 1,000,000 SUN)
MIN_TASK_AMOUNT=1000000

# Maximum task amount in SUN
MAX_TASK_AMOUNT=1000000000000

# Default deadline in hours
DEFAULT_DEADLINE_HOURS=72
